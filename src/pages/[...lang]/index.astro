---
import Layout from '../../layouts/Layout.astro';
import EventCard from '../../components/EventCard.astro';
import SurfWidget from '../../components/SurfWidget.astro';
import SpinTheWheel from '../../components/SpinTheWheel.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations, getFallbackCollectionItems } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: undefined } },
    { params: { lang: 'en' } },
    { params: { lang: 'es' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

import treeImg from '../../assets/images/tree.png';
import posnerImg from '../../assets/images/posnerfamily.png';
import shabbatImg from '../../assets/images/shabbat.png';

const allEvents = await getCollection('events');
const today = new Date();
today.setHours(0, 0, 0, 0);
const rawEvents = getFallbackCollectionItems(lang, allEvents);
const events = rawEvents.filter(entry => entry.data.date >= today);
// Sort by date ascending
const sortedEvents = events.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const basePath = lang === 'he' ? '' : '/' + lang;
const allPosts = await getCollection('blog');
const rawPosts = getFallbackCollectionItems(lang, allPosts);
const latestPosts = rawPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 3);
---

<Layout title={t('nav.home')} description={t('about.p1')}>
    <section class="hero">
        <div class="container hero-content">
            <h1>{t('hero.title')}</h1>
            <p>{t('hero.subtitle')}</p>
            <a href="#schedule" class="button button-primary cta-button">{t('hero.cta')}</a>
        </div>
        <div class="hero-overlay"></div>
    </section>

    <section id="about" class="about-section">
        <div class="container about-container">
            <div class="container">
               <h2>{t('about.title')}</h2>
                <p><strong>{t('about.p1.strong')}</strong><br>
            {t('about.p1')}</p>

                <p>{t('about.p2')}</p>

                <h3 style="margin-top: 2rem;">{t('about.bina.title')}</h3>
                <p>{t('about.bina.desc')}</p>
            </div>
            <div class="about-images">
                <Image src={posnerImg} alt="Posner family" class="about-img main-about-img" />
            </div>
        </div>
    </section>

    <section id="schedule" class="schedule-section">
        <div class="container">
            <div class="schedule-header-flex">
                <h2>{t('schedule.title')}</h2>
                <a href={`${basePath}/schedule`} class="weekly-link">{t('schedule.weeklyLink') || "Weekly Schedule"}</a>
            </div>
            <div class="events-grid">
                {sortedEvents.length > 0 ? (
                    sortedEvents.map(event => (
                        <EventCard event={event} />
                    ))
                ) : (
                    <p>{t('schedule.empty')}</p>
                )}
            </div>
        </div>
    </section>

    <SpinTheWheel />

    <section id="latest-blog" class="blog-section">
        <div class="container">
            <h2>{t('home.blogTitle')}</h2>
            <div class="blog-grid">
                {latestPosts.length > 0 ? (
                    latestPosts.map(post => {
                        const img = post.data.image && post.data.image.trim() !== '' ? post.data.image : null;
                        const locale = lang === 'he' ? 'he-IL' : lang === 'es' ? 'es-CR' : 'en-US';
                        const formattedDate = new Intl.DateTimeFormat(locale, {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        }).format(post.data.date);
                        
                        return (
                        <article class="blog-card">
                            {img && (
                                <div class="blog-image-wrapper">
                                    <Image src={img} alt={post.data.title} width={600} height={400} class="blog-image" />
                                </div>
                            )}
                            <div class="blog-content">
                                <h3>{post.data.title}</h3>
                                <span class="blog-date">{formattedDate}</span>
                                {post.data.description && <p class="blog-desc">{post.data.description}</p>}
                                <a href={`${basePath}/blog/${post.data.permalink || post.id.split('/').pop().replace('.md', '')}`} class="button button-primary details-link">{t('recs.readmore')}</a>
                            </div>
                        </article>
                        );
                    })
                ) : (
                    <p class="no-posts">{t('blog.empty')}</p>
                )}
            </div>
            <div class="view-all-blog">
                <a href={`${basePath}/blog`} class="view-all-link">{t('home.viewAllBlog')}</a>
            </div>
        </div>
    </section>

    <section id="shabbat-passover" class="shabbat-section">
        <div class="container shabbat-container">
            <div class="shabbat-image-wrapper">
                 <Image src={shabbatImg} alt="Shabbat Dinner" class="shabbat-img round-img" />
            </div>
            <div class="shabbat-content">
                <h2>{t('shabbat.title')}</h2>
                <p>{t('shabbat.desc')}</p>
                <div class="shabbat-actions">
                    <a href="https://bit.ly/40P4Q7W" class="button button-primary" target="_blank" rel="noopener noreferrer">{t('shabbat.cta')}</a>
                </div>
            </div>
        </div>
    </section>



    <section id="surf-widget" class="widget-section">
        <div class="container">
            <SurfWidget />
        </div>
    </section>
</Layout>

<style>
    .hero {
        position: relative;
        background-color: var(--color-brand-blue);
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: var(--color-white);
        margin-block-start: -1px; /* Overlap header box-shadow */
        overflow: hidden;
    }

    .hero-bg-image {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
    }

    .hero-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 140, 255, 0.4); /* Brand blue with opacity */
        z-index: 1;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
    }

    .hero h1 {
        font-size: 2.5rem;
        margin-block-end: 1rem;
        color: var(--color-white);
        line-height: 1.2;
    }

    .hero p {
        font-size: 1.25rem;
        margin-block-end: 2rem;
    }

    .cta-button {
        font-size: 1.25rem;
        padding: 1rem 2rem;
    }

    .about-section {
        padding-block: 5rem;
        background-color: var(--color-white);
    }

    .about-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
    }

    @media (min-width: 900px) {
        .about-container {
            grid-template-columns: 1fr 1fr;
        }
    }

    .about-text h2 {
        font-size: 2rem;
        margin-block-end: 1.5rem;
    }

    .about-text p {
        font-size: 1.15rem;
        line-height: 1.7;
        color: var(--color-text);
    }
    
    .about-images {
        position: relative;
        min-height: 350px;
    }

    .about-img {
        border-radius: 12px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
        object-fit: cover;
    }

    .main-about-img {
        width: 100%;
        height: auto;
        position: relative;
        z-index: 2;
    }

    .schedule-section {
        padding-block: 4rem;
        background-color: var(--color-sand-light);
    }

    .schedule-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-block-end: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .schedule-header-flex h2 {
        margin-block-end: 0;
    }

    .weekly-link {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-brand-blue);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .weekly-link:hover {
        text-decoration: underline;
    }

    .events-grid {
        display: grid;
        gap: 2rem;
        grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
        .events-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .hero h1 {
            font-size: 3.5rem;
        }
    }
    
    @media (min-width: 1024px) {
        .events-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .shabbat-section {
        padding-block: 5rem;
        background-color: var(--color-brand-green);
        color: var(--color-white);
    }
    
    .passover-section {
        padding-block: 5rem;
        background-color: var(--color-brand-blue);
        color: var(--color-white);
    }

    .widget-section {
        padding-block: 4rem;
        background-color: var(--color-sand-light);
    }

    .blog-section {
        padding-block: 5rem;
        background-color: var(--color-white);
    }

    .blog-section h2 {
        text-align: center;
        margin-block-end: 2.5rem;
        font-size: 2.2rem;
        color: var(--color-jungle-green);
    }

    .blog-grid {
        display: grid;
        gap: 2rem;
        grid-template-columns: 1fr;
    }

    @media (min-width: 768px) {
        .blog-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (min-width: 1024px) {
        .blog-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    .blog-card {
        background-color: var(--color-sand-light);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        border: 1px solid var(--color-sand);
        display: flex;
        flex-direction: column;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .blog-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 15px rgba(0,0,0,0.1);
    }

    .blog-image-wrapper {
        width: 100%;
        height: 200px;
        overflow: hidden;
    }

    .blog-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .blog-content {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }
    
    .blog-content h3 {
        margin-block-start: 0;
        margin-block-end: 0.5rem;
        font-size: 1.25rem;
        color: var(--color-jungle-green);
    }
    
    .blog-date {
        color: var(--color-warm-wood);
        font-size: 0.9rem;
        margin-block-end: 1rem;
    }
    
    .blog-desc {
        margin-block-start: 0;
        margin-block-end: 1.5rem;
        line-height: 1.5;
        color: var(--color-text);
    }

    .details-link {
        margin-block-start: auto;
    }

    .no-posts {
        text-align: center;
        grid-column: 1 / -1;
        font-size: 1.1rem;
        color: var(--color-warm-wood);
    }

    .view-all-blog {
        text-align: center;
        margin-block-start: 3rem;
    }

    .view-all-link {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--color-brand-blue);
        text-decoration: none;
        transition: color 0.3s ease;
        padding: 0.5rem 1.5rem;
        border: 2px solid var(--color-brand-blue);
        border-radius: 4px;
    }

    .view-all-link:hover {
        background-color: var(--color-brand-blue);
        color: var(--color-white);
    }

    .shabbat-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3rem;
        align-items: center;
    }

    @media (min-width: 900px) {
        .shabbat-container {
            grid-template-columns: auto 1fr;
        }
        .passover-container {
            grid-template-columns: 1fr auto;
        }
    }

    .shabbat-image-wrapper {
        text-align: center;
    }

    .round-img {
        width: 100%;
        max-width: 350px;
        height: auto;
        border-radius: 50%;
        border: 4px solid var(--color-white);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        object-fit: cover;
        aspect-ratio: 1;
    }

    .shabbat-content {
        text-align: start;
    }
    
    @media (max-width: 899px) {
        .shabbat-content {
            text-align: center;
        }
        .shabbat-actions {
            justify-content: center;
        }
    }

    .shabbat-section h2, .passover-section h2 {
        color: var(--color-text-bright);
        font-size: 2.2rem;
        margin-block-end: 1rem;
    }

    .shabbat-content p {
        font-size: 1.15rem;
        color: var(--color-white);
        max-width: 600px;
        margin-block-end: 2rem;
        line-height: 1.6;
    }
    
    .passover-content p {
        font-size: 1.15rem;
        color: var(--color-text-bright);
        max-width: 600px;
        margin-block-end: 2rem;
        line-height: 1.6;
    }

    .shabbat-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }
    
    .passover-actions .button {
        background-color: var(--color-brand-red);
        color: var(--color-white);
    }
    
    .passover-actions .button:hover {
        opacity: 0.9;
    }
    
    /* Ensure the non-primary button in Shabbat section stands out better on wood bg */
    .shabbat-actions .button:not(.button-primary) {
        background-color: var(--color-sand);
        color: var(--color-text);
        text-decoration: none;
    }
    .shabbat-actions .button:not(.button-primary):hover {
        background-color: var(--color-white);
        text-decoration: none;
    }
</style>
