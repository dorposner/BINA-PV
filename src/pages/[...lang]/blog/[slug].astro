import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getLangFromUrl, useTranslations, getFallbackCollectionItems } from '../../../i18n/utils';
import PostEngagement from '../../../components/PostEngagement.astro';

export async function getStaticPaths() {
    const posts = await getCollection('blog');
    
    const locales = [
        { lang: undefined, id: 'he' },
        { lang: 'en', id: 'en' },
        { lang: 'es', id: 'es' }
    ];
    
    return locales.flatMap(locale => {
        const items = getFallbackCollectionItems(locale.id, posts);
        return items.map(post => ({
            params: { lang: locale.lang, slug: post.data.permalink || post.id.split('/').pop().replace('.md', '') },
            props: { post }
        }));
    });
}

const { post } = Astro.props;
const { title, description, image, date, author } = post.data;
const { Content } = await post.render();

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const basePath = lang === 'he' ? '' : '/' + lang;

const locale = lang === 'he' ? 'he-IL' : lang === 'es' ? 'es-CR' : 'en-US';
const formattedDate = new Intl.DateTimeFormat(locale, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
}).format(date);
---

<Layout title={title} description={description} image={image}>
    <article class="single-post container">
        <header class="post-header">
            <a href={`${basePath}/blog`} class="back-link">{lang === 'he' ? '← חזרה לבלוג' : '← Back to Blog'}</a>
            <h1>{title}</h1>
            {author && <p class="post-author" style="font-weight: bold; color: var(--color-brand-blue);">{t('blog.by')} {author}</p>}
            <time class="post-date">{formattedDate}</time>
        </header>

        {image && image.trim() !== '' && (
            <div class="main-image-wrapper">
                 <Image src={image} alt={title} width={800} height={600} class="main-image" />
            </div>
        )}

        <div class="post-body">
            <Content />
        </div>

        <PostEngagement url={Astro.url.href} title={title} slug={Astro.params.slug as string} />
    </article>
</Layout>

<style>
    .single-post {
        padding-block: 3rem 5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .post-header {
        margin-block-end: 2rem;
        border-bottom: 2px solid var(--color-sand);
        padding-block-end: 1.5rem;
    }

    .back-link {
        color: var(--color-warm-wood);
        font-weight: 500;
        display: inline-block;
        margin-block-end: 1rem;
    }

    .post-header h1 {
        font-size: 2.5rem;
        margin-block-end: 0.5rem;
        color: var(--color-jungle-green);
    }
    
    .post-date {
        color: var(--color-warm-wood);
        font-size: 1rem;
    }

    .main-image-wrapper {
        border-radius: 8px;
        overflow: hidden;
        margin-block-end: 3rem;
        max-height: 500px;
    }

    .main-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .post-body {
        font-size: 1.15rem;
        line-height: 1.8;
        color: var(--color-text);
        margin-block-end: 3rem;
    }
    
    .post-body :global(p) {
        margin-block-end: 1.5rem;
    }

    .post-body :global(h2), .post-body :global(h3) {
        color: var(--color-jungle-green);
        margin-block-top: 2rem;
        margin-block-end: 1rem;
    }
    
    .post-body :global(img) {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin-block: 2rem;
    }
</style>
